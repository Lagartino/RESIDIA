// ═══════════════ RENTAL INVOICE GENERATOR ═══════════════
// FISCAL ENGINE — determines IVA and retención automatically
function fiscalEngine(prop, reserva){
  const alq = prop.alquiler || {};
  const rules = { iva:0, ivaRate:0, ivaMotivo:'', ret:false, retRate:0, retMotivo:'', warnings:[], errors:[], notas:[] };

  // ── IVA RULES ──
  // Art. 20.Uno.23º LIVA: arrendamiento de vivienda exento, SALVO si se prestan servicios
  // complementarios propios de industria hotelera (limpieza durante estancia, recepción, etc.)
  if(alq.tipo==='turistico' && !alq.servicios){
    rules.ivaRate=0;
    rules.ivaMotivo='Exento de IVA — arrendamiento turístico sin servicios hoteleros (art. 20.1.23º LIVA)';
    rules.notas.push('Alquiler turístico sin servicios complementarios: exento de IVA conforme al art. 20.Uno.23º de la Ley 37/1992 del IVA.');
  } else if(alq.tipo==='turistico' && alq.servicios){
    rules.ivaRate=10;
    rules.ivaMotivo='IVA 10% — alojamiento turístico con servicios hoteleros (art. 91.Uno.2.2º LIVA)';
    rules.notas.push('Al prestar servicios complementarios (limpieza durante estancia, recepción, etc.), se aplica el tipo reducido del 10% de IVA.');
  } else if(alq.tipo==='larga_estancia'){
    rules.ivaRate=0;
    rules.ivaMotivo='Exento de IVA — arrendamiento de vivienda habitual (art. 20.1.23º LIVA)';
    rules.notas.push('Arrendamiento de vivienda para uso habitual del arrendatario: exento de IVA.');
  }

  // ── RETENCIÓN IRPF RULES ──
  // Art. 31.1 LIRNR: obligación de retener cuando el pagador es empresa/profesional español
  if(reserva.tipoArr==='empresa_es'){
    rules.ret=true;
    rules.retRate=19;
    rules.retMotivo='Retención 19% obligatoria — arrendatario es empresa/profesional español (art. 31.1 LIRNR)';
    rules.notas.push('El arrendatario, al ser empresa o profesional con establecimiento en España, está obligado a practicar retención del 19% sobre las rentas del arrendamiento e ingresarla mediante modelo 216.');
  } else if(reserva.tipoArr==='profesional_es'){
    rules.ret=true;
    rules.retRate=19;
    rules.retMotivo='Retención 19% obligatoria — arrendatario es profesional español obligado a retener';
  } else if(reserva.tipoArr==='particular_ext'){
    rules.ret=false;
    rules.retMotivo='Sin retención — arrendatario es particular no residente/extranjero, sin obligación de retener';
  } else if(reserva.tipoArr==='particular_es'){
    rules.ret=false;
    rules.retMotivo='Sin retención — particular sin obligación de retener';
    rules.notas.push('Los particulares no están obligados a practicar retención. El propietario declarará los rendimientos mediante el modelo 210.');
  } else {
    rules.ret=false;
    rules.retMotivo='Sin retención aplicable';
  }

  // ── VALIDACIONES ──
  if(!prop.alquiler || !prop.alquiler.licencia){
    rules.warnings.push('Este inmueble no tiene licencia turística registrada. Es obligatoria en la mayoría de CCAA para alquiler vacacional.');
  }
  if(!D.user.nie){
    rules.warnings.push('No tienes NIE registrado. Será necesario para la presentación del M210 asociado a estos ingresos.');
  }
  if(reserva.canal==='Booking' || reserva.canal==='Airbnb'){
    rules.notas.push('Las plataformas ('+reserva.canal+') pueden retener e ingresar impuestos en determinadas jurisdicciones. Verifica en tu extracto de la plataforma si ya se ha practicado alguna retención o ingreso fiscal.');
  }
  if(reserva.noches > 31 && alq.tipo==='turistico'){
    rules.errors.push('Estancia de '+reserva.noches+' noches en un inmueble configurado como turístico. Las estancias superiores a 31 días pueden requerir contrato de larga estancia. Revisa la configuración del inmueble.');
  }

  // Calculate amounts
  const base = reserva.imp;
  rules.iva = Math.round(base * rules.ivaRate / 100 * 100) / 100;
  const retAmt = rules.ret ? Math.round(base * rules.retRate / 100 * 100) / 100 : 0;
  rules.total = base + rules.iva - retAmt;
  rules.retAmount = retAmt;
  rules.base = base;

  return rules;
}

