          <button class="b b-s" onclick="verBorrador()">📄 Ver borrador</button><button class="b b-s" onclick="contactAsesor()">💬 Contactar asesor</button>
          ${`</div><div style="font-size:10px;margin-top:6px;color:${D.user.aeatAccess?'var(--green-text)':'var(--amber-text)'}">${D.user.aeatAccess?'🔐 Sesión con certificado — presentación directa habilitada':'⚠️ Accede con certificado digital o Cl@ve para poder autorizar la presentación'}</div>`}`:''}
