          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="card-header"><span class="card-title">Próximos vencimientos fiscales</span><button class="btn btn-sm" onclick="nav('tributos',document.querySelectorAll('.sb-item')[3])">Calendario →</button></div>
        <table>
          <thead><tr><th>Modelo</th><th>Inmueble</th><th>Vence</th><th>Estado</th></tr></thead>
          <tbody>
            <tr><td><b>M210 T3</b></td><td>Apto. Estepona</td><td>20 ene 2025</td><td><span class="badge badge-amber">Pendiente</span></td></tr>
