// ═══════════════ COMPLETION RING ═══════════════
function renderComplRing(){
  // Calculate overall profile/data completion
  let total=0, ok=0;
  D.props.forEach(p=>{
    if(p.checklist.declarante){total+=p.checklist.declarante.total;ok+=p.checklist.declarante.ok}
    if(p.checklist.docs){total+=p.checklist.docs.total;ok+=p.checklist.docs.ok}
  });
  // Add NIE check
  total++;if(D.user.nie)ok++;
  const pct=Math.round(ok/total*100);
  const circ=2*Math.PI*15; // r=15
  const offset=circ*(1-pct/100);
  const color=pct>=90?'var(--green-mid)':pct>=60?'var(--amber-text)':'var(--red-mid)';
  $('complRing').innerHTML=`<svg width="36" height="36" viewBox="0 0 36 36"><circle class="bg" cx="18" cy="18" r="15"/><circle class="fg" cx="18" cy="18" r="15" stroke="${color}" stroke-dasharray="${circ}" stroke-dashoffset="${offset}"/></svg><div class="txt" style="color:${color}">${pct}%</div>`;
  $('complRing').title=`Perfil completado: ${pct}% (${ok}/${total})`;
}

