    <!-- Global checklist rendered by JS -->
    <div class="c" id="resumenChecklist"></div>
  </div>
</div>

<!-- ══════════════ PERFIL FISCAL ══════════════ -->
<div class="pg" id="pg-perfil">
  <div class="al al-i">ℹ️ <div><b>Datos del Modelo 210</b>Completa todos los campos. ResidIA los usa para preparar y presentar tu declaración ante la AEAT.</div></div>
  <div class="g2">
    <div class="c">
      <div class="sec">Identificación</div>
      <div class="f2">
        <div class="fg"><label class="fl">Nombre completo</label><input class="fi" value="Johan Erik Henriksson"/></div>
        <div class="fg"><label class="fl">NIE español</label><input class="fi" placeholder="X1234567A"/><span class="fh">⚠ Obligatorio para el M210</span></div>
        <div class="fg"><label class="fl">Pasaporte / DNI origen</label><input class="fi" value="SE-AB123456"/></div>
        <div class="fg"><label class="fl">Fecha de nacimiento</label><input class="fi" type="date" value="1975-03-15"/></div>
      </div>
      <div class="hr"></div>
      <div class="sec">Residencia fiscal</div>
      <div class="f2">
        <div class="fg"><label class="fl">País de residencia</label><select class="fi"><option selected>Suecia (UE) — 19%</option><option>Alemania (UE) — 19%</option><option>Francia (UE) — 19%</option><option>Reino Unido — 19%</option><option>EE.UU. — 24%</option><option>Fuera UE — 24%</option></select></div>
        <div class="fg"><label class="fl">Certificado residencia fiscal</label><select class="fi"><option>Sí, vigente</option><option selected>Pendiente de aportar</option><option>No tengo</option></select></div>
        <div class="fg"><label class="fl">Dirección en el extranjero</label><input class="fi" value="Storgatan 14, Estocolmo"/></div>
        <div class="fg"><label class="fl">Código postal</label><input class="fi" value="11122"/></div>
      </div>
      <div class="hr"></div>
      <div class="sec">Cuenta bancaria (devoluciones AEAT)</div>
