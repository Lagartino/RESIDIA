  });

  if(p.declHist.length){
    html+=`<div style="margin-top:.5rem"><button class="b b-ghost b-s" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">📁 Ver ejercicio 2023</button><div style="display:none;margin-top:.75rem">`;
