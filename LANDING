        <div class="price-val">9 €</div>
        <div class="price-period">por mes · hasta 5 inmuebles</div>
        <div class="price-feats">
          <div class="pf">Hasta 5 inmuebles</div>
          <div class="pf">M210 guiado completo</div>
          <div class="pf">Alertas por email y SMS</div>
          <div class="pf">Panel de rentabilidad</div>
          <div class="pf">Acceso para 1 gestor</div>
        </div>
        <button class="price-btn green">Contratar plan</button>
      </div>
      <div class="price-card">
        <div class="price-name">Inversor</div>
        <div class="price-val">19 €</div>
        <div class="price-period">por mes · inmuebles ilimitados</div>
        <div class="price-feats">
          <div class="pf">Inmuebles ilimitados</div>
          <div class="pf">Informes exportables</div>
          <div class="pf">API para gestorías</div>
          <div class="pf">Soporte prioritario</div>
          <div class="pf">Multi-gestor</div>
        </div>
        <button class="price-btn">Ver detalles</button>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="contacto">
    <div class="footer-logo">Resid<span>IA</span></div>
    <div>© 2025 · Diseñado para no residentes en España</div>
    <div class="footer-links">
      <a>Privacidad</a>
      <a>Términos</a>
      <a>Contacto</a>
    </div>
  </footer>

</body>
