<script>
const titles={resumen:'Resumen',inmuebles:'Mis inmuebles',alquileres:'Alquileres',tributos:'Obligaciones tributarias',documentos:'Documentos'};

function nav(id,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(el) el.classList.add('active');
  document.getElementById('page-title').textContent=titles[id]||id;
}

function showFicha(idx){
  document.querySelectorAll('.prop-card').forEach((c,i)=>c.classList.toggle('selected',i===idx));
  for(let i=0;i<3;i++){
    const f=document.getElementById('ficha-'+i);
    if(f) f.style.display=i===idx?'block':'none';
  }
}

function alqTab(el,id){
  document.querySelectorAll('.alq-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  ['contratos','historial','inquilinos'].forEach(k=>{
    const d=document.getElementById('alq-'+k);
    if(d) d.style.display=k===id?'block':'none';
  });
}

function calcM210(){
  const ing=parseFloat(document.getElementById('ingresos').value)||0;
  const gas=parseFloat(document.getElementById('gastos').value)||0;
  const base=Math.max(0,ing-gas);
  const cuota=Math.round(base*0.15);
  document.getElementById('base').textContent=base.toLocaleString('es-ES')+' €';
  document.getElementById('cuota').textContent=cuota.toLocaleString('es-ES')+' €';
