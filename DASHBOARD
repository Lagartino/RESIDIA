            <tr><td><b>Renta imputada</b></td><td>Villa Mijas</td><td>31 dic 2025</td><td><span class="badge badge-gray">Anual</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- INMUEBLES -->
  <div class="page" id="page-inmuebles">
    <div class="three-col" style="margin-bottom:1.5rem">
      <div class="prop-card selected" onclick="showFicha(0)">
        <div class="prop-img" style="background:linear-gradient(135deg,#9FE1CB,#E1F5EE)">🏠</div>
