    <div class="al al-ok" style="margin-bottom:1rem">✅ <div><b>Resumen de tu suscripción</b>Revisa los datos antes de confirmar.</div></div>
    <div class="dr"><span class="dr-l">Plan</span><span class="dr-v">Anual · ${D.props.length} inmuebles</span></div>
    <div class="dr"><span class="dr-l">Precio</span><span class="dr-v">${D.props.length*50} €/año</span></div>
    <div class="dr"><span class="dr-l">Presentación M210</span><span class="dr-v">+5 €/modelo al presentar</span></div>
    <div class="dr" style="border-bottom:none"><span class="dr-l">Cancelación</span><span class="dr-v">Sin permanencia</span></div>
    <div class="hr"></div>
    <div class="fg"><label class="fl">Tarjeta de pago</label><input class="fi" placeholder="1234 5678 9012 3456"/></div>
    <div class="f2">
      <div class="fg"><label class="fl">Caducidad</label><input class="fi" placeholder="MM/AA"/></div>
      <div class="fg"><label class="fl">CVV</label><input class="fi" placeholder="123" type="password"/></div>
    </div>
    <div style="font-size:10px;color:var(--text3);display:flex;align-items:center;gap:4px;margin-top:4px"><span style="color:var(--green-mid)">🔒</span> Pago seguro mediante Stripe · Tus datos bancarios están cifrados</div>`,
    `<button class="b" onclick="closeModal()">Cancelar</button><button class="b b-g" onclick="closeModal();toast('✅ Plan anual activado correctamente','ok')">Confirmar y pagar ${D.props.length*50} €</button>`
  );
}

// ═══════════════ EDITAR INMUEBLE ═══════════════
function editarInmueble(){
  const p=D.props[curProp];
  openModal('Editar · '+p.name,`
    <div class="f2">
      <div class="fg"><label class="fl">Nombre</label><input class="fi" value="${p.name}"/></div>
      <div class="fg"><label class="fl">Tipo</label><select class="fi"><option ${p.type==='Apartamento'?'selected':''}>Apartamento</option><option ${p.type==='Villa'?'selected':''}>Villa</option><option>Estudio</option><option>Local</option></select></div>
      <div class="fg"><label class="fl">Ciudad</label><input class="fi" value="${p.city}"/></div>
      <div class="fg"><label class="fl">Dirección</label><input class="fi" value="${p.addr}"/></div>
      <div class="fg"><label class="fl">Ref. catastral</label><input class="fi" value="${p.ref}"/></div>
      <div class="fg"><label class="fl">% propiedad</label><input class="fi" type="number" value="${p.pct}"/></div>
      <div class="fg"><label class="fl">Valor catastral (€)</label><input class="fi" type="number" value="${p.vc}"/></div>
      <div class="fg"><label class="fl">Uso</label><select class="fi"><option ${p.uso.includes('vacacional')?'selected':''}>Alquiler vacacional</option><option ${p.uso==='Uso propio'?'selected':''}>Uso propio</option><option>Larga estancia</option><option>Mixto</option></select></div>
    </div>`,
    `<button class="b" onclick="closeModal()">Cancelar</button><button class="b b-g" onclick="closeModal();toast('✅ Inmueble actualizado','ok');renderProp()">Guardar cambios</button>`
  );
}

// ═══════════════ CAMBIAR MÉTODO DE PAGO ═══════════════
function cambiarMetodoPago(){
  openModal('Cambiar método de pago',`
    <div style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--surface2);border-radius:var(--r);margin-bottom:1rem">
      <div style="width:42px;height:28px;background:linear-gradient(135deg,#1a1f71,#2e77bc);border-radius:4px;display:flex;align-items:center;justify-content:center;color:white;font-size:9px;font-weight:700">VISA</div>
      <div><div style="font-size:12px;font-weight:500">•••• 4821</div><div style="font-size:10px;color:var(--text3)">Método actual</div></div>
    </div>
    <div class="fg"><label class="fl">Nuevo número de tarjeta</label><input class="fi" placeholder="1234 5678 9012 3456"/></div>
    <div class="f2">
      <div class="fg"><label class="fl">Caducidad</label><input class="fi" placeholder="MM/AA"/></div>
      <div class="fg"><label class="fl">CVV</label><input class="fi" placeholder="123" type="password"/></div>
    </div>
    <div class="fg"><label class="fl">Titular</label><input class="fi" value="${D.user.name}"/></div>`,
    `<button class="b" onclick="closeModal()">Cancelar</button><button class="b b-g" onclick="closeModal();toast('✅ Método de pago actualizado','ok')">Guardar tarjeta</button>`
  );
}

// ═══════════════ CAMBIAR EMAIL FACTURACIÓN ═══════════════
function cambiarEmailFact(){
  openModal('Email de facturación',`
    <div class="fg"><label class="fl">Email actual</label><input class="fi" value="${D.company.email}" disabled style="opacity:.6"/></div>
    <div class="fg"><label class="fl">Nuevo email</label><input class="fi" placeholder="tu@email.com" type="email"/></div>`,
    `<button class="b" onclick="closeModal()">Cancelar</button><button class="b b-g" onclick="closeModal();toast('✅ Email actualizado','ok')">Guardar</button>`
  );
}

// ═══════════════ PAUSAR / CANCELAR PLAN ═══════════════
function pausarPlan(){
  openModal('Pausar suscripción',`
    <div class="al al-w" style="margin-bottom:1rem">⚠️ <div><b>Al pausar tu plan:</b>Se mantendrán tus datos e inmuebles, pero no podrás acceder a actividad económica ni se presentarán M210 hasta que reactives.</div></div>
    <div class="fg"><label class="fl">Motivo (opcional)</label><select class="fi"><option>Temporalmente no alquilo</option><option>Quiero evaluar otras opciones</option><option>Motivos económicos</option><option>Otro</option></select></div>`,
    `<button class="b" onclick="closeModal()">Volver</button><button class="b" style="color:var(--red-text);border-color:var(--red)" onclick="closeModal();toast('⏸️ Suscripción pausada','w')">Confirmar pausa</button>`
  );
}
function cancelarPlan(){
  openModal('Cancelar plan',`
    <div class="al al-w" style="margin-bottom:1rem">⚠️ <div><b>¿Estás seguro?</b>Perderás acceso a actividad económica y presentación M210. Tus datos e inmuebles se conservarán 90 días.</div></div>
    <div class="fg"><label class="fl">Para confirmar, escribe CANCELAR</label><input class="fi" id="cancelConfirm" placeholder="CANCELAR"/></div>`,
    `<button class="b" onclick="closeModal()">Volver</button><button class="b" style="color:var(--red-text);border-color:var(--red)" onclick="if($('cancelConfirm').value==='CANCELAR'){closeModal();toast('Plan cancelado','w')}else{toast('Escribe CANCELAR para confirmar','w')}">Cancelar plan</button>`
  );
}

// ═══════════════ NUEVA RESERVA ═══════════════
function nuevaReserva(){
  openModal('Nueva reserva',`
    <div class="f2">
      <div class="fg"><label class="fl">Inmueble</label><select class="fi">${D.props.filter(p=>p.diasAlq>0).map(p=>`<option>${p.name}</option>`).join('')}</select></div>
      <div class="fg"><label class="fl">Canal</label><select class="fi"><option>Directo</option><option>Booking</option><option>Airbnb</option></select></div>
      <div class="fg"><label class="fl">Huésped</label><input class="fi" placeholder="Nombre completo"/></div>
      <div class="fg"><label class="fl">Doc. identidad</label><input class="fi" placeholder="Pasaporte / NIF"/></div>
      <div class="fg"><label class="fl">Check-in</label><input class="fi" type="date"/></div>
      <div class="fg"><label class="fl">Check-out</label><input class="fi" type="date"/></div>
      <div class="fg"><label class="fl">Precio/noche (€)</label><input class="fi" type="number" placeholder="130"/></div>
      <div class="fg"><label class="fl">Tipo arrendatario</label><select class="fi"><option value="particular_ext">Particular no residente</option><option value="particular_es">Particular residente España</option><option value="empresa_es">Empresa española</option></select></div>
    </div>`,
    `<button class="b" onclick="closeModal()">Cancelar</button><button class="b b-g" onclick="closeModal();toast('✅ Reserva creada','ok')">Crear reserva</button>`
  );
}

