// ═══════════════ SIMULADOR FISCAL INTERACTIVO ═══════════════
let simDias=187, simIngresos=24800, simGastos=4280;
function renderSim(){
  const p=D.props[0]; // primary rental property
  const rate=D.user.rate;

  // Calculate IRNR with current slider values
  const diasImp=365-simDias;
  const baseAlq=simIngresos-simGastos;
  const baseAlqSinGastos=simIngresos;
  const cuotaAlq=Math.round(Math.max(0,baseAlq)*rate/100);
  const cuotaAlqSinGastos=Math.round(baseAlqSinGastos*rate/100);
  const baseImp=Math.round(p.vc*p.tipImp/100*diasImp/365);
  const cuotaImp=Math.round(baseImp*rate/100);
  const totalCuota=cuotaAlq+cuotaImp;
  const totalSinGastos=cuotaAlqSinGastos+cuotaImp;
  const ahorro=totalSinGastos-totalCuota;

  $('simContent').innerHTML=`
  <div class="al al-i" style="margin-bottom:1.25rem">🧮 <div><b>Simulador en tiempo real</b>Mueve los controles y observa cómo cambia tu cuota IRNR. Los cálculos se basan en los datos de <b>${p.name}</b>.</div></div>

  <div class="g2" style="align-items:start">
    <div>
      <div class="c">
        <div class="c-h"><span class="c-t">Variables del ejercicio</span><span class="bd bd-b">${p.name}</span></div>

        <div class="slider-wrap">
          <div class="slider-head"><span class="slider-label">Días alquilados</span><span class="slider-val" id="simDiasVal">${simDias} noches</span></div>
          <input type="range" min="0" max="365" value="${simDias}" oninput="simDias=+this.value;renderSim()"/>
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:2px"><span>0 (uso propio)</span><span>365 (todo alquilado)</span></div>
        </div>

        <div class="slider-wrap">
          <div class="slider-head"><span class="slider-label">Ingresos brutos alquiler</span><span class="slider-val" id="simIngVal">${fmt(simIngresos)} €</span></div>
          <input type="range" min="0" max="80000" step="100" value="${simIngresos}" oninput="simIngresos=+this.value;renderSim()"/>
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:2px"><span>0 €</span><span>80.000 €</span></div>
        </div>

        <div class="slider-wrap">
          <div class="slider-head"><span class="slider-label">Gastos deducibles</span><span class="slider-val" id="simGasVal">${fmt(simGastos)} €</span></div>
          <input type="range" min="0" max="30000" step="50" value="${simGastos}" oninput="simGastos=+this.value;renderSim()"/>
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:2px"><span>0 €</span><span>30.000 €</span></div>
        </div>

        <div class="hr"></div>
        <div style="font-size:11px;color:var(--text3);line-height:1.6">
          <b style="color:var(--text2)">Datos fijos del inmueble:</b><br/>
          Valor catastral: ${fmt(p.vc)} € · Tipo imputación: ${p.tipImp}% · Tipo IRNR: ${rate}% (${D.user.zone})
        </div>
      </div>

      <!-- ESCENARIO COMPARATIVO -->
      <div class="c" style="background:var(--green-pale);border-color:var(--green-soft)">
        <div class="c-h"><span class="c-t" style="color:var(--green)">🔄 ¿Y si alquilas Villa Mijas también?</span></div>
        <div style="font-size:12px;color:var(--green-text);line-height:1.6;margin-bottom:10px">
          Si alquilaras la Villa Mijas 120 noches a 180 €/noche con 3.500 € de gastos:
        </div>
        <div class="dr"><span class="dr-l">Ingresos Villa Mijas</span><span class="dr-v" style="color:var(--green)">+21.600 €</span></div>
        <div class="dr"><span class="dr-l">IRNR adicional estimado</span><span class="dr-v" style="color:var(--amber-text)">+3.439 €</span></div>
        <div class="dr"><span class="dr-l">Ahorro vs dejar vacía</span><span class="dr-v" style="color:var(--green)">−439 € imputada</span></div>
        <div class="dr" style="border-bottom:none"><span class="dr-l" style="font-weight:500;color:var(--green-text)">Beneficio neto estimado</span><span class="dr-v" style="color:var(--green);font-size:16px">+18.600 €</span></div>
      </div>
    </div>

    <div>
      <!-- RESULTADO PRINCIPAL -->
      <div class="sim-hero" style="background:linear-gradient(135deg,${totalCuota>2000?'#fef2f2,#fef3c7':'#ecfdf5,#eff6ff'});border:1px solid ${totalCuota>2000?'rgba(185,28,28,.1)':'rgba(16,185,129,.1)'};margin-bottom:1.25rem">
        <div style="font-size:11px;color:var(--text2);margin-bottom:8px">Tu cuota IRNR estimada</div>
        <div class="sim-hero-val" style="color:${totalCuota>2000?'var(--red-text)':'var(--green)'}">${fmt(totalCuota)} €</div>
        <div class="sim-hero-sub" style="color:var(--text2)">Ejercicio 2024 · ${p.name}</div>
      </div>

      <!-- DESGLOSE -->
      <div class="c">
        <div class="c-h"><span class="c-t">Desglose del cálculo</span></div>
        <div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">M210 Tipo 35 — Alquiler</div>
        <div class="dr"><span class="dr-l">Ingresos brutos</span><span class="dr-v">${fmt(simIngresos)} €</span></div>
        <div class="dr"><span class="dr-l">Gastos deducibles</span><span class="dr-v" style="color:var(--green-mid)">−${fmt(simGastos)} €</span></div>
        <div class="dr"><span class="dr-l">Base imponible neta</span><span class="dr-v">${fmt(Math.max(0,baseAlq))} €</span></div>
        <div class="dr" style="border-bottom:none"><span class="dr-l">Cuota (${rate}%)</span><span class="dr-v" style="color:var(--red-text)">${fmt(cuotaAlq)} €</span></div>

        <div class="hr"></div>
        <div style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">M210 Tipo 2 — Imputada</div>
        <div class="dr"><span class="dr-l">Días no alquilados</span><span class="dr-v">${diasImp} días</span></div>
        <div class="dr"><span class="dr-l">Base imputada</span><span class="dr-v">${fmt(baseImp)} €</span></div>
        <div class="dr" style="border-bottom:none"><span class="dr-l">Cuota (${rate}%)</span><span class="dr-v" style="color:var(--amber-text)">${fmt(cuotaImp)} €</span></div>

        <div class="hr"></div>
        <div class="dr" style="border-bottom:none;font-size:14px;font-weight:600"><span>Total IRNR</span><span style="color:var(--red-text)">${fmt(totalCuota)} €</span></div>
      </div>

      <!-- COMPARATIVA GASTOS -->
      <div class="c">
        <div class="c-h"><span class="c-t">Impacto de los gastos deducibles</span></div>
        <div class="comp-bar">
          <div style="width:${Math.round(totalCuota/totalSinGastos*100)}%;background:var(--green);color:#ecfdf5">${fmt(totalCuota)} €</div>
          <div style="width:${Math.round(ahorro/totalSinGastos*100)}%;background:var(--red);color:var(--red-text)">${fmt(ahorro)} €</div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:10px">
          <span>Con gastos deducibles</span><span>Sin deducir gastos: ${fmt(totalSinGastos)} €</span>
        </div>
        <div style="text-align:center;padding:12px;background:var(--green-pale);border-radius:var(--r)">
          <div style="font-size:11px;color:var(--green-text)">Ahorro por deducir gastos</div>
          <div style="font-size:24px;font-weight:700;color:var(--green);letter-spacing:-.5px">${fmt(ahorro)} €</div>
          <div style="font-size:10px;color:var(--green-text)">${Math.round(ahorro/totalSinGastos*100)}% menos de impuestos</div>
        </div>
      </div>
    </div>
  </div>`;
}

// ═══════════════ DASHBOARD RENTABILIDAD ═══════════════
function renderRent(){
  const props=D.props.map(p=>{
    const ingresos=p.diasAlq?Math.round(p.diasAlq*132):0; // avg nightly rate
    const gastosTot=p.ibi+p.comunidad+(p.seguro||0);
    const irnr=p.decl.reduce((a,d)=>a+d.cuota,0);
    const netoPre=ingresos-gastosTot;
    const netoPost=ingresos-gastosTot-irnr;
    const roi=p.valAdq>0?Math.round(netoPost/p.valAdq*1000)/10:0;
    const roiBruto=p.valAdq>0?Math.round(ingresos/p.valAdq*1000)/10:0;
    return {...p,ingresos,gastosTot,irnr,netoPre,netoPost,roi,roiBruto};
  });

  const totalIngresos=props.reduce((a,p)=>a+p.ingresos,0);
  const totalGastos=props.reduce((a,p)=>a+p.gastosTot,0);
  const totalIRNR=props.reduce((a,p)=>a+p.irnr,0);
  const totalNeto=totalIngresos-totalGastos-totalIRNR;

  $('rentContent').innerHTML=`
  <div class="g4">
    <div class="kpi"><div class="kpi-l">Ingresos brutos</div><div class="kpi-v">${fmt(totalIngresos)} €</div><div class="kpi-s up">${D.props.length} inmuebles</div></div>
    <div class="kpi"><div class="kpi-l">Gastos totales</div><div class="kpi-v">${fmt(totalGastos)} €</div><div class="kpi-s warn">IBI + comunidad + seguro</div></div>
    <div class="kpi"><div class="kpi-l">IRNR total</div><div class="kpi-v">${fmt(totalIRNR)} €</div><div class="kpi-s err">Impuestos 2024</div></div>
    <div class="kpi"><div class="kpi-l">Beneficio neto</div><div class="kpi-v">${fmt(totalNeto)} €</div><div class="kpi-s ${totalNeto>0?'up':'err'}">${totalNeto>0?'Positivo':'Negativo'}</div></div>
  </div>

  <div class="g2" style="align-items:start">
    <div>
      <!-- PER-PROPERTY CARDS -->
      ${props.map(p=>`<div class="c">
        <div class="c-h"><span class="c-t">${p.icon} ${p.name}</span><span class="bd ${p.roi>3?'bd-g':p.roi>0?'bd-a':'bd-r'}">ROI ${p.roi}%</span></div>
        <div style="display:flex;gap:1.25rem;margin-bottom:1rem">
          <div style="flex:1;text-align:center;padding:12px;background:var(--surface2);border-radius:var(--r)">
            <div style="font-size:10px;color:var(--text3)">Ingresos</div>
            <div style="font-size:18px;font-weight:600;color:var(--green-mid)">${fmt(p.ingresos)} €</div>
          </div>
          <div style="flex:1;text-align:center;padding:12px;background:var(--surface2);border-radius:var(--r)">
            <div style="font-size:10px;color:var(--text3)">Gastos + IRNR</div>
            <div style="font-size:18px;font-weight:600;color:var(--red-text)">${fmt(p.gastosTot+p.irnr)} €</div>
          </div>
          <div style="flex:1;text-align:center;padding:12px;background:${p.netoPost>0?'var(--green-pale)':'var(--red)'};border-radius:var(--r)">
            <div style="font-size:10px;color:var(--text3)">Neto</div>
            <div style="font-size:18px;font-weight:600;color:${p.netoPost>0?'var(--green)':'var(--red-text)'}">${fmt(p.netoPost)} €</div>
          </div>
        </div>
        <div class="dr"><span class="dr-l">Valor adquisición</span><span class="dr-v">${fmt(p.valAdq)} €</span></div>
        <div class="dr"><span class="dr-l">ROI bruto</span><span class="dr-v">${p.roiBruto}%</span></div>
        <div class="dr"><span class="dr-l">ROI neto (tras impuestos)</span><span class="dr-v" style="color:${p.roi>0?'var(--green-mid)':'var(--red-text)'}">${p.roi}%</span></div>
        <div class="dr" style="border-bottom:none"><span class="dr-l">Ocupación</span><span class="dr-v">${p.diasAlq?Math.round(p.diasAlq/365*100)+'%':'No alquilado'}</span></div>
        ${p.roi>0?`<div class="roi-meter" style="margin-top:8px"><div class="roi-meter-fill" style="width:${Math.min(p.roi*10,100)}%;background:${p.roi>5?'var(--green-mid)':p.roi>2?'var(--amber-text)':'var(--red-mid)'}"></div></div>`:''}
      </div>`).join('')}
    </div>

    <div>
      <!-- DISTRIBUCIÓN INGRESOS -->
      <div class="c">
        <div class="c-h"><span class="c-t">Distribución por inmueble</span></div>
        ${props.filter(p=>p.ingresos>0).map(p=>{
          const pct=Math.round(p.ingresos/totalIngresos*100);
          return `<div style="margin-bottom:10px"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px"><span>${p.icon} ${p.name}</span><span class="dr-v">${fmt(p.ingresos)} € (${pct}%)</span></div><div class="bar"><div class="bar-f" style="width:${pct}%;background:var(--green-mid)"></div></div></div>`;
        }).join('')}
        ${props.filter(p=>p.ingresos===0).map(p=>`<div style="display:flex;justify-content:space-between;font-size:12px;padding:8px 0;color:var(--text3)">${p.icon} ${p.name}<span>Sin ingresos</span></div>`).join('')}
      </div>

      <!-- WATERFALL: INCOME → NET -->
      <div class="c">
        <div class="c-h"><span class="c-t">De ingresos a beneficio neto</span></div>
        <div style="display:flex;flex-direction:column;gap:6px;font-size:12px">
          <div class="dr"><span class="dr-l">Ingresos brutos</span><span class="dr-v" style="color:var(--green-mid)">+${fmt(totalIngresos)} €</span></div>
          <div class="dr"><span class="dr-l">IBI</span><span class="dr-v" style="color:var(--red-text)">−${fmt(props.reduce((a,p)=>a+p.ibi,0))} €</span></div>
          <div class="dr"><span class="dr-l">Comunidad</span><span class="dr-v" style="color:var(--red-text)">−${fmt(props.reduce((a,p)=>a+p.comunidad,0))} €</span></div>
          <div class="dr"><span class="dr-l">Seguros</span><span class="dr-v" style="color:var(--red-text)">−${fmt(props.reduce((a,p)=>a+(p.seguro||0),0))} €</span></div>
          <div class="dr"><span class="dr-l">IRNR (impuestos)</span><span class="dr-v" style="color:var(--red-text)">−${fmt(totalIRNR)} €</span></div>
          <div class="hr" style="margin:.5rem 0"></div>
          <div class="dr" style="border-bottom:none;font-weight:600;font-size:14px"><span>Beneficio neto</span><span style="color:${totalNeto>0?'var(--green)':'var(--red-text)'}">${fmt(totalNeto)} €</span></div>
        </div>
      </div>

      <!-- QUICK INSIGHT -->
      <div class="c" style="background:var(--blue);border-color:rgba(30,64,175,.1)">
        <div style="font-size:12px;font-weight:500;color:var(--blue-text);margin-bottom:6px">💡 Insight ResidIA</div>
        <div style="font-size:12px;color:var(--blue-text);line-height:1.6">${
          totalNeto>0
            ?`Tu cartera inmobiliaria genera un rendimiento neto positivo de <b>${fmt(totalNeto)} €</b> anuales tras impuestos. ${props.some(p=>p.ingresos===0)?'Considera alquilar <b>'+props.find(p=>p.ingresos===0).name+'</b> para maximizar el retorno y reducir la renta imputada.':''}`
            :`Tu cartera tiene rendimiento negativo. Revisa los gastos deducibles que puedas estar omitiendo — cada euro deducido reduce tu IRNR un ${D.user.rate}%.`
        }</div>
      </div>
    </div>
  </div>`;
}

