// Helper to get translated string
function t(key){return (i18n[lang]&&i18n[lang][key])||i18n.es[key]||key}

function toggleLangMenu(){$('langDd').classList.toggle('on')}
document.addEventListener('click',e=>{if(!e.target.closest('.lang-sw'))$('langDd').classList.remove('on')});

function setLang(l){
  lang=l;
  $('langDd').classList.remove('on');
  // Update button
  $('langBtn').innerHTML=`${LANGS[l]} ${l.toUpperCase()} ▾`;
  // Update dropdown active state
  $$('.lang-item').forEach(item=>{
    const itemLang=item.getAttribute('onclick').match(/'(\w+)'/)[1];
    item.classList.toggle('on',itemLang===l);
  });
  // Update sidebar nav labels
  $$('.sb-btn[data-pg]').forEach(btn=>{
    const pg=btn.dataset.pg;
    const txt=t(pg);
    if(txt && txt!==pg){
      const emoji=btn.textContent.trim().match(/^[\p{Emoji}\u200d]+/u);
      const emojiStr=emoji?emoji[0]:'';
      const pill=btn.querySelector('.pill, .lock-ico');
      const pillHtml=pill?` ${pill.outerHTML}`:'';
      btn.innerHTML=`${emojiStr} ${txt}${pillHtml}`;
    }
  });
  // Update search placeholder
  const si=$('searchInput');
  if(si)si.placeholder=t('search');
  // Update top title
  const curPage=document.querySelector('.pg.on');
  if(curPage){
    const pgId=curPage.id.replace('pg-','');
    $('topTitle').textContent=t(pgId);
  }
  // Update lock banner
  const lb=$('lockBanner');
  if(lb){
    lb.querySelector('div:nth-child(2) > div:first-child').textContent=t('locked_title');
    lb.querySelector('div:nth-child(2) > div:last-child').textContent=t('locked_desc');
    lb.querySelector('.b').innerHTML=t('see_plan')+' →';
  }
  // Re-render data-driven sections to pick up translated labels
  renderResumen();renderNotifs();
  toast(t('toast_lang'),'ok');
}

// ═══════════════ SIMULADOR FISCAL INTERACTIVO ═══════════════
let sim={
  propIdx:0,
  diasAlq:187, ingresos:24800, gastos:4280,
  scenarioOn:false, scDiasAlq:120, scIngresos:15600, scGastos:2800
};

function renderSimulador(){
  const p=D.props[sim.propIdx];
  const rate=D.user.rate;

  // ── T35 Calculation (rental income) ──
  const baseT35=Math.max(0, sim.ingresos - (D.user.zone==='UE'?sim.gastos:0));
  const cuotaT35=Math.round(baseT35 * rate/100);

  // ── T2 Calculation (imputed income for non-rented days) ──
  const diasImp=365-sim.diasAlq;
  const baseT2=Math.round(p.vc * p.tipImp/100 * diasImp/365);
  const cuotaT2=Math.round(baseT2 * rate/100);

  const totalIRNR=cuotaT35+cuotaT2;

  // ── Comparison: without deductible expenses ──
  const cuotaSinGastos=Math.round(sim.ingresos * rate/100);
  const ahorro=cuotaSinGastos-cuotaT35;

  // ── Scenario (if enabled) ──
  let scHtml='';
  if(sim.scenarioOn){
    const scP=D.props[1]||D.props[0];
    const scBaseT35=Math.max(0, sim.scIngresos - (D.user.zone==='UE'?sim.scGastos:0));
    const scCuotaT35=Math.round(scBaseT35 * rate/100);
    const scDiasImp=365-sim.scDiasAlq;
    const scBaseT2=Math.round(scP.vc * scP.tipImp/100 * scDiasImp/365);
    const scCuotaT2=Math.round(scBaseT2 * rate/100);
    const scTotal=scCuotaT35+scCuotaT2;
    const newGrandTotal=totalIRNR+scTotal;
    const newIngresos=sim.ingresos+sim.scIngresos;

    scHtml=`
    <div class="sim-scenario active">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
        <div><div style="font-size:13px;font-weight:600">🔄 Escenario: ¿Y si alquilo ${scP.name}?</div><div style="font-size:11px;color:var(--text3)">Simulando alquiler vacacional en tu segundo inmueble</div></div>
        <button class="b b-s" onclick="sim.scenarioOn=false;renderSimulador()">✕ Cerrar</button>
      </div>
      <div class="sim-row"><div class="sim-label"><div class="sim-label-t">Días alquilados</div><div class="sim-label-d">${scP.name}</div></div><div class="sim-slider"><input type="range" min="0" max="365" value="${sim.scDiasAlq}" oninput="sim.scDiasAlq=+this.value;renderSimulador()"/></div><div class="sim-val">${sim.scDiasAlq} días</div></div>
      <div class="sim-row"><div class="sim-label"><div class="sim-label-t">Ingresos brutos</div></div><div class="sim-slider"><input type="range" min="0" max="60000" step="100" value="${sim.scIngresos}" oninput="sim.scIngresos=+this.value;renderSimulador()"/></div><div class="sim-val">${fmt(sim.scIngresos)} €</div></div>
      <div class="sim-row" style="border-bottom:none"><div class="sim-label"><div class="sim-label-t">Gastos deducibles</div></div><div class="sim-slider"><input type="range" min="0" max="20000" step="50" value="${sim.scGastos}" oninput="sim.scGastos=+this.value;renderSimulador()"/></div><div class="sim-val">${fmt(sim.scGastos)} €</div></div>

      <div style="margin-top:1rem;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
