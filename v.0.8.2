// ═══════════════ SEARCH ═══════════════
function handleSearch(q){
  if(!q.trim()){closeModal();return}
  q=q.toLowerCase();
  let results=[];
  // Search props
  D.props.forEach(p=>{if((p.name+p.city+p.addr+p.ref).toLowerCase().includes(q))results.push({ico:p.icon,t:p.name,d:p.addr+', '+p.city,action:`curProp=${p.id};go('inmuebles')`})});
  // Search docs
  D.docs.forEach(d=>{if((d.n+d.prop+d.tipo).toLowerCase().includes(q))results.push({ico:'📄',t:d.n.replace(/^.{2}/,'').trim(),d:d.prop+' · '+d.f,action:`go('documentos')`})});
  // Search pages
  Object.entries(titles).forEach(([k,v])=>{if(v.toLowerCase().includes(q))results.push({ico:'📂',t:v,d:'Ir a sección',action:`go('${k}')`})});
  if(!results.length)results=[{ico:'🔍',t:'Sin resultados',d:'No se encontraron coincidencias para "'+q+'"',action:null}];
  const html=results.map(r=>`<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);${r.action?'cursor:pointer':''}" ${r.action?`onclick="closeModal();${r.action}"`:''}>
    <div style="width:36px;height:36px;border-radius:var(--r);background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0">${r.ico}</div>
    <div><div style="font-size:13px;font-weight:500">${r.t}</div><div style="font-size:11px;color:var(--text3)">${r.d}</div></div>
  </div>`).join('');
  openModal('Resultados de búsqueda',html);
}

