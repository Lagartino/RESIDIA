let pI=2,pM=2;
function pChange(t,d){
  if(t==='inm')pI=Math.max(1,pI+d);else pM=Math.max(1,pM+d);
  if($('pInm'))$('pInm').textContent=pI;
  if($('pMod'))$('pMod').textContent=pM;
  const el=$(t==='inm'?'pInm':'pMod');
  if(el){el.style.transform='scale(1.2)';setTimeout(()=>el.style.transform='scale(1)',150)}
  pCalc();
}
function pCalc(){
  if(!$('pMes')||!$('pResult'))return;
  const m=+$('pMes').value,mR=m-1,a=pI*50,r=Math.round(a/12*mR),m210=pM*5;
  const mN=['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  let h=`<div class="dr"><span class="dr-l">Plan anual (${pI} inm. × 50€)</span><b>${a} €/año</b></div>`;
  if(mR>0)h+=`<div class="dr"><span class="dr-l">Regularización ene–${mN[m-1]} (${mR} m.)</span><b style="color:var(--amber-text)">+${r} €</b></div>`;
  h+=`<div class="dr"><span class="dr-l">Presentación M210 (${pM} × 5€)</span><b>${m210} € <span style="font-weight:400;font-size:10px;color:var(--text3)">en enero sig.</span></b></div>`;
  h+=`<div class="dr" style="border-bottom:none;padding-top:8px;font-weight:500;font-size:13px"><span>Primer pago (${mN[m]})</span><span style="color:var(--green);font-size:16px">${a+r} €</span></div>`;
  h+=`<div style="font-size:11px;color:var(--text2);margin-top:6px;padding-top:6px;border-top:1px solid var(--border)">${mR===0?'✅ Sin regularización — empiezas desde enero.':'ℹ️ Incluye '+mR+' meses de regularización (ene–'+mN[m-1]+').'}</div>`;
  $('pResult').innerHTML=h;
}

