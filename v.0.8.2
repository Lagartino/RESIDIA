// ═══════════════ HELPERS ═══════════════
const $=s=>document.getElementById(s);
const $$=s=>document.querySelectorAll(s);
const fmt=n=>n.toLocaleString('es-ES');
const titles={resumen:'Resumen',perfil:'Perfil fiscal',inmuebles:'Mis inmuebles',actividad:'Actividad económica',ingresos:'Ingresos y reservas',calendario:'Calendario',gastos:'Gastos y facturas',documentos:'Documentos',plan:'Mi plan',simulador:'Simulador fiscal',rentabilidad:'Rentabilidad','actividad-feed':'Actividad'};

let dev=false, curProp=0, curPropTab='datos';

// ═══════════════ NAVIGATION ═══════════════
function go(id){
  if(!dev && ['ingresos','calendario','gastos'].includes(id)){id='actividad'}
  $$('.pg').forEach(p=>p.classList.remove('on'));
  $$('.sb-btn').forEach(b=>b.classList.remove('on'));
  const pg=$('pg-'+id);
  if(pg){pg.classList.add('on');pg.style.animation='none';pg.offsetHeight;pg.style.animation=''}
  const btn=document.querySelector(`.sb-btn[data-pg="${id}"]`);
  if(btn && (!btn.classList.contains('locked')||dev)) btn.classList.add('on');
  $('topTitle').textContent=t(id);
  if(id==='plan')renderPlan();
  if(id==='inmuebles')renderProp();
  document.querySelector('.main').scrollTo({top:0,behavior:'smooth'});
  closeSb();
}

// Sidebar click handler
document.addEventListener('click',e=>{
  const btn=e.target.closest('.sb-btn');
  if(!btn)return;
  const pg=btn.dataset.pg;
  if(btn.classList.contains('locked')&&!dev){go('actividad');return}
  go(pg);
});

// ═══════════════ RENDER: RESUMEN ═══════════════
function renderResumen(){
  const totalIRNR=D.props.reduce((s,p)=>s+p.decl.reduce((a,d)=>a+d.cuota,0),0);
  const totalDecl=D.props.reduce((s,p)=>s+p.decl.length,0);
  const urgentDecl=D.props.flatMap(p=>p.decl.filter(d=>d.estado==='urgent'));

  // KPIs
  $('kpiGrid').innerHTML=`
    <div class="kpi"><div class="kpi-l">${t('kpi_inm')}</div><div class="kpi-v">${D.props.length}</div><div class="kpi-s up">${t('kpi_registered')}</div></div>
    <div class="kpi"><div class="kpi-l">${t('kpi_decl')} 2024</div><div class="kpi-v">${totalDecl}</div><div class="kpi-s warn">${t('kpi_managed')}</div></div>
    <div class="kpi"><div class="kpi-l">${t('kpi_irnr')}</div><div class="kpi-v">${fmt(totalIRNR)} €</div><div class="kpi-s warn">${t('kpi_exercise')} 2024</div></div>
    <div class="kpi"><div class="kpi-l">${t('kpi_acciones')}</div><div class="kpi-v">${urgentDecl.length}</div><div class="kpi-s ${urgentDecl.length?'err':'up'}">${urgentDecl.length?t('kpi_attention'):t('kpi_ok')}</div></div>`;

  // Urgent
  if(urgentDecl.length){
    const d=urgentDecl[0], p=D.props.find(p=>p.decl.includes(d));
    $('urgentAlert').innerHTML=`<div class="al al-w">⚠️ <div><b>M210 ${d.tipo} · ${p.name} — Vence ${d.plazo}</b>ResidIA está preparando tu declaración. Pendiente de tu autorización.</div><button class="b b-s" style="margin-left:auto;flex-shrink:0" onclick="go('inmuebles')">Ver →</button></div>`;
  }

  // Inmuebles table
  let rows=D.props.map(p=>{
    const irnr=p.decl.reduce((a,d)=>a+d.cuota,0);
    const st=p.decl.some(d=>d.estado==='urgent')?'<span class="bd bd-a">Pendiente auth.</span>':'<span class="bd bd-0">En prep.</span>';
    return `<tr onclick="go('inmuebles')" style="cursor:pointer"><td><b>${p.name}</b><br><span style="font-size:10px;color:var(--text2)">VC: ${fmt(p.vc)} € · ${p.tipImp}%</span></td><td>${p.uso}</td><td>${fmt(irnr)} €</td><td>${st}</td></tr>`;
  }).join('');
  $('resumenInmuebles').innerHTML=`<div class="c-h"><span class="c-t">${t('my_properties')}</span><button class="b b-s" onclick="go('inmuebles')">${t('view_sheets')} →</button></div><table><thead><tr><th>${t('property')}</th><th>${t('type')}</th><th>IRNR</th><th>${t('status')}</th></tr></thead><tbody>${rows}</tbody></table>`;

  // Global checklist — only pending items across all props
  let pending=[];
  D.props.forEach(p=>{
    if(p.checklist.declarante.items)p.checklist.declarante.items.filter(i=>!i.ok).forEach(i=>pending.push({...i,from:p.name}));
    if(p.checklist.docs&&p.checklist.docs.items)p.checklist.docs.items.filter(i=>!i.ok).forEach(i=>pending.push({...i,from:p.name}));
  });
  // Deduplicate by title
  const seen=new Set();pending=pending.filter(i=>{if(seen.has(i.t))return false;seen.add(i.t);return true});
  let ckHtml=pending.map(i=>`<div class="ck"><div class="ck-i ck-w">!</div><div><div style="font-weight:500">${i.t}</div><div style="color:var(--text3);font-size:10px">${i.d}</div></div></div>`).join('');
  $('resumenChecklist').innerHTML=`<div class="c-h"><span class="c-t">${t('checklist_m210')}</span><span class="bd bd-a">${pending.length} ${t('actions')}</span></div>${ckHtml}<div style="margin-top:.75rem;display:flex;gap:8px;flex-wrap:wrap"><button class="b b-g b-s" onclick="go('perfil')">${t('complete_profile')}</button><button class="b b-s" onclick="go('documentos')">${t('upload_docs')}</button></div>`;
}

// ═══════════════ RENDER: PERFIL FISCAL SUMMARY ═══════════════
function renderFiscal(){
  $('fiscalSummary').innerHTML=D.fiscal.map(f=>`<div class="dr"><span class="dr-l">${f.label}</span><span style="font-weight:500;color:var(--green)">${f.val}</span></div>`).join('');
}

// ═══════════════ RENDER: INMUEBLE DETAIL ═══════════════
function renderProp(){
  const p=D.props[curProp];
  // Tabs
  $('propTabs').innerHTML=D.props.map((pr,i)=>`<div class="tab ${i===curProp?'on':''}" onclick="curProp=${i};curPropTab='datos';renderProp()">${pr.icon} ${pr.name}</div>`).join('')+`<div class="tab" style="color:var(--text3)" onclick="openAddPropModal()">＋ Añadir</div>`;

  // Sub-tabs + content
  let html=`<div class="stabs">
    <button class="stab ${curPropTab==='datos'?'on':''}" onclick="curPropTab='datos';renderProp()">Datos</button>
    <button class="stab ${curPropTab==='m210'?'on':''}" onclick="curPropTab='m210';renderProp()">Declaraciones M210 ${p.decl.some(d=>d.estado==='urgent')?'<span style=\"background:var(--amber);color:var(--amber-dk);font-size:9px;padding:1px 5px;border-radius:10px;margin-left:3px\">!</span>':''}</button>
    <button class="stab ${curPropTab==='check'?'on':''}" onclick="curPropTab='check';renderProp()">Checklist</button>
  </div>`;

  if(curPropTab==='datos') html+=renderPropDatos(p);
  else if(curPropTab==='m210') html+=renderPropM210(p);
  else html+=renderPropCheck(p);
  $('propContent').innerHTML=html;
}

