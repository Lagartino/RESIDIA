function loginPassword(){
  const nie=$('loginNie').value.trim().toUpperCase();
  const pass=$('loginPass').value.trim().toUpperCase();
  // Default: NIE is both user and password
  if(!nie){$('loginError').textContent='⛔ Introduce tu NIE.';$('loginError').classList.add('show');return}
  // Accept the demo NIE or any valid-looking NIE format
  const validFormat=/^[XYZ]\d{7}[A-Z]$/.test(nie);
  if(!validFormat){
    $('loginError').textContent='⛔ Formato de NIE incorrecto. El NIE debe tener formato X0000000A (letra + 7 dígitos + letra).';
    $('loginError').classList.add('show');
    return;
  }
  // Check password (default = same NIE)
  if(pass!==nie && pass!==''){
    $('loginError').textContent='⛔ Contraseña incorrecta. Recuerda: por defecto tu contraseña es tu propio NIE.';
    $('loginError').classList.add('show');
    return;
  }
  // Accept empty password with NIE as default
  if(!pass || pass===nie){
    // Update user NIE in the data model
    D.user.nie=nie;
    completeLogin('password');
  }
}

function completeLogin(method){
  authMethod=method;
  $('loginWrap').classList.add('hidden');

  // Update session tag in topbar
  const labels={cert:'Certificado digital',clave:'Cl@ve',password:'NIE + Contraseña'};
  const classes={cert:'session-cert',clave:'session-clave',password:'session-pass'};
  const icons={cert:'🔐',clave:'🏛️',password:'👤'};
  const tag=$('sessionTag');
  tag.style.display='flex';
  tag.innerHTML=`<div class="session-tag ${classes[method]}" onclick="showSessionInfo()">${icons[method]} ${labels[method]}</div>`;

  // If cert or clave, user has AEAT presentation capability
  if(method==='cert' || method==='clave'){
    D.user.aeatAccess=true;
  } else {
    D.user.aeatAccess=false;
  }

  // Re-render everything with updated auth state
  renderResumen();renderComplRing();renderNotifs();renderSbFoot();renderPerfilAsesor();
  toast('Sesión iniciada'+(method==='cert'?' con certificado digital':method==='clave'?' vía Cl@ve':''),'ok');
}

