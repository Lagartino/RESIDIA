      </div>
      <div>
        <div class="sec">Financiero 2024</div>
        <div class="dr"><span class="dr-l">Valor adquisición</span><span class="dr-v">${fmt(p.valAdq)} €</span></div>
        <div class="dr"><span class="dr-l">IBI anual</span><span>${fmt(p.ibi)} €</span></div>
        <div class="dr"><span class="dr-l">Comunidad</span><span>${fmt(p.comunidad)} €</span></div>
        ${p.seguro?`<div class="dr"><span class="dr-l">Seguro hogar</span><span>${fmt(p.seguro)} €</span></div>`:''}
        ${p.diasAlq?`<div class="dr" style="border-bottom:none;font-weight:500"><span>Ingresos alquiler</span><span style="color:var(--green-mid);cursor:pointer" onclick="go('plan')">Activa plan →</span></div>`:''}
      </div>
      <div>
